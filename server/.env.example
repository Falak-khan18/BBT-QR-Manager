# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bbt_qr

# JWT
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Base URL used in API responses for QR redirect links (no trailing slash)
# For phone scan demos, use your LAN IP or tunnel (not localhost), e.g. http://192.168.1.42:8000
REDIRECT_BASE_URL=http://localhost:8000
